# Copy this file to .env and fill in your key:
#   cp .env.example .env

# Which LLM answers your questions. One of: anthropic | openai | nvidia | ollama
LLM_PROVIDER=anthropic

# --- Anthropic (Claude) --- default provider, used if LLM_PROVIDER=anthropic
# Get a key at console.anthropic.com
ANTHROPIC_API_KEY=your-api-key-here
CLAUDE_MODEL=claude-sonnet-5

# --- OpenAI --- used if LLM_PROVIDER=openai
# Get a key at platform.openai.com
# OPENAI_API_KEY=your-openai-key
# OPENAI_MODEL=gpt-4o-mini

# --- NVIDIA API Catalog --- used if LLM_PROVIDER=nvidia
# Get a key at build.nvidia.com (OpenAI-compatible endpoint, many hosted models)
# NVIDIA_API_KEY=your-nvidia-key
# NVIDIA_MODEL=minimaxai/minimax-m3

# --- Ollama (free, local, no API key needed) --- used if LLM_PROVIDER=ollama
# Install from ollama.com, run `ollama serve`, then `ollama pull llama3.2` (or your model of choice)
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional overrides
CHUNK_SIZE=400
CHUNK_OVERLAP=80
TOP_K=3
